/* NXP Platform Configuration - Auto-generated by CMake */
#ifndef NXP_PLATFORM_CONFIG_H
#define NXP_PLATFORM_CONFIG_H

/* Platform */
#define NXP_PLATFORM_@NXP_PLATFORM@ 1

/* I/O backends */
#cmakedefine01 NXP_HAS_IOCP
#cmakedefine01 NXP_HAS_EPOLL
#cmakedefine01 NXP_HAS_IO_URING

/* C23 feature availability */
#cmakedefine01 NXP_HAS_STDCKDINT
#cmakedefine01 NXP_HAS_STDBIT

/* Linux UDP features */
#cmakedefine01 NXP_HAS_UDP_GRO
#cmakedefine01 NXP_HAS_UDP_GSO

/* Protocol version */
#define NXP_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define NXP_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define NXP_VERSION_PATCH @PROJECT_VERSION_PATCH@

#endif /* NXP_PLATFORM_CONFIG_H */
