)\n\t\tvar n int\n\t\tfor {\n\t\t\tnr, rerr := stream.Read(buf[n:])\n\t\t\tif nr > 0 {\n\t\t\t\tn += nr\n\t\t\t}\n\t\t\tif rerr != nil {\n\t\t\t\tif errors.Is(rerr, io.EOF) {\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t\tvar nxpErr *nxp.Error\n\t\t\t\tif errors.As(rerr, &nxpErr) && nxpErr.Code == nxp.ErrWouldBlock {\n\t\t\t\t\ttime.Sleep(2 * time.Millisecond)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tclientRecv = string(buf[:n])\n\t}\n\n\t// Wait for server goroutine result.\n\tvar serverRecv string\n\tselect {\n\tcase serverRecv = <-serverRecvCh:\n\tcase <-time.After(timeout):\n\t\tlog.Printf(\"[%s] server goroutine timed out\", tc.name)\n\t\treturn false\n\t}\n\n\t// ── Stats ─────────────────────────────────────────────\n\tstats := conn.Statistics()\n\tlog.Printf(\"[%s] sent=%dB pkts=%d rtt=%dµs cwnd=%d\",\n\t\ttc.name, stats.BytesSent, stats.PacketsSent, stats.RTTSmoothedUs, stats.CWnd)\n\n\t// ── Verify ────────────────────────────────────────────\n\tif serverRecv != msg {\n\t\tlog.Printf(\"[%s] server got %q, want %q\", tc.name, serverRecv, msg)\n\t\treturn false\n\t}\n\tif tc.stype == nxp.StreamReliable || tc.stype == nxp.StreamFile {\n\t\tif clientRecv != msg {\n\t\t\tlog.Printf(\"[%s] echo got %q, want %q\", tc.name, clientRecv, msg)\n\t\t\treturn false\n\t\t}\n\t}\n\treturn true\n}\n",
