                "file_text": "package main\n\n// test_tcp.go — NXP over TCP transport end-to-end echo test.\n//\n// Real-world usage: server listens on ntc://, client connects, opens a\n// file-transfer stream, sends a large payload, verifies the echo.\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"log\"\n\t\"nxp\"\n\t\"strings\"\n\t\"time\"\n)\n\nconst tcpPort = 9410\n\nfunc testTCP() bool {\n\tconst timeout = 8 * time.Second\n\taddr := fmt.Sprintf(\"ntc://127.0.0.1:%d\", tcpPort)\n\n\tsrv, err := nxp.ListenRawURL(addr)\n\tif err != nil {\n\t\tlog.Printf(\"[tcp] listen: %v\", err)\n\t\treturn false\n\t}\n\tdefer srv.Close()\n\n\tsrvDone := make(chan string, 1)\n\n\t// Server: accept → accept stream → read full payload → echo back\n\tgo func() {\n\t\tctx, cancel := context.WithTimeout(context.Background(), timeout)\n\t\tdefer cancel()\n\n\t\tconn, err := srv.AcceptContext(ctx)\n\t\tif err != nil {\n\t\t\tlog.Printf(\"[tcp][srv] accept: %v\", err)\n\t\t\tsrvDone <- \"\"\n\t\t\treturn\n\t\t}\n\t\tdefer conn.Close()\n\t\tconn.WaitReady(ctx)\n\n\t\tstream, err := conn.AcceptStream(ctx)\n\t\tif err != nil {\n\t\t\tlog.Printf(\"[tcp][srv] AcceptStream: %v\", err)\n\t\t\tsrvDone <- \"\"\n\t\t\treturn\n\t\t}\n\t\tdefer stream.Close()\n\n\t\tvar sb strings.Builder\n\t\tbuf := make([]byte, 4096)\n\t\tfor {\n\t\t\tn, err := stream.Read(buf)\n\t\t\tif n > 0 {\n\t\t\t\tsb.Write(buf[:n])\n\t\t\t}\n\t\t\tif err != nil {\n\t\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t\tvar e *nxp.Error\n\t\t\t\tif errors.As(err, &e) && e.Code == nxp.ErrWouldBlock {\n\t\t\t\t\ttime.Sleep(2 * time.Millisecond)\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\tpayload := sb.String()\n\t\tstream.WriteFin([]byte(payload)) // echo\n\t\tsrvDone <- payload\n\t}()\n\n\t// Client: connect → open file stream → send 4 KB payload → verify echo\n\tctx, cancel := context.WithTimeout(context.Background(), timeout)\n\tdefer cancel()\n\n\tconn, err := nxp.DialRawURL(ctx, addr)\n\tif err != nil {\n\t\tlog.Printf(\"[tcp][cli] dial: %v\", err)\n\t\treturn false\n\t}\n\tdefer conn.Close()\n\n\tif err := conn.WaitReady(ctx); err != nil {\n\t\tlog.Printf(\"[tcp][cli] WaitReady: %v\", err)\n\t\treturn false\n\t}\n\n\tstream, err := conn.OpenStream(nxp.StreamFile)\n\tif err != nil {\n\t\tlog.Printf(\"[tcp][cli] OpenStream: %v\", err)\n\t\treturn false\n\t}\n\tdefer stream.Close()\n\n\t// Build 4 KB payload\n\tpayload := strings.Repeat(\"NXP-TCP-DATA:\", 320) // ~4 KB\n\tstream.WriteFin([]byte(payload))\n\n\t// Wait for server to receive\n\tsrvPayload := <-srvDone\n\tif srvPayload != payload {\n\t\tlog.Printf(\"[tcp] server payload mismatch (got %d bytes, want %d)\", len(srvPayload), len(payload))\n\t\treturn false\n\t}\n\n\t// Read echo\n\tvar sb strings.Builder\n\tbuf := make([]byte, 4096)\n\tdeadline := time.Now().Add(timeout)\n\tfor time.Now().Before(deadline) {\n\t\tn, err := stream.Read(buf)\n\t\tif n > 0 {\n\t\t\tsb.Write(buf[:n])\n\t\t}\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tvar e *nxp.Error\n\t\t\tif errors.As(err, &e) && e.Code == nxp.ErrWouldBlock {\n\t\t\t\ttime.Sleep(2 * time.Millisecond)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tbreak\n\t\t}\n\t}\n\n\techo := sb.String()\n\tif echo != payload {\n\t\tlog.Printf(\"[tcp] echo mismatch (got %d bytes, want %d)\", len(echo), len(payload))\n\t\treturn false\n\t}\n\n\tlog.Printf(\"[tcp] OK  payload=%d bytes echoed correctly\", len(payload))\n\treturn true\n}\n",
