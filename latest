                    "Text": "// go_echo — NXP end-to-end echo example\n//\n// Tests NXP, TCP and WebSocket transports one by one.\n//\n// Usage: go run .\npackage main\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"log\"\n\t\"nxp\"\n\t\"time\"\n)\n\nfunc main() {\n\tlog.SetFlags(log.Ltime | log.Lmicroseconds)\n\tfmt.Println(\"=== NXP Go Echo Example ===\")\n\tdefer nxp.GracefulShutdown()\n\n\tresults := []struct {\n\t\tname string\n\t\tpass bool\n\t}{\n\t\t{\"NXP Reliable\", testNXP(9400, nxp.StreamReliable, \"NXP-Reliable\")},\n\t\t{\"NXP Fast\", testNXP(9401, nxp.StreamFast, \"NXP-Fast\")},\n\t\t{\"NXP File\", testNXP(9402, nxp.StreamFile, \"NXP-File\")},\n\t}\n\n\tfmt.Println()\n\tfails := 0\n\tfor _, r := range results {\n\t\tstatus := \"PASS\"\n\t\tif !r.pass {\n\t\t\tstatus = \"FAIL\"\n\t\t\tfails++\n\t\t}\n\t\tfmt.Printf(\"  %-20s %s\\n\", r.name, status)\n\t}\n\tfmt.Println()\n\tif fails == 0 {\n\t\tfmt.Println(\"PASS\")\n\t} else {\n\t\tfmt.Printf(\"FAIL (%d/%d)\\n\", fails, len(results))\n\t}\n}\n\n// testNXP runs a full echo over NXP for the given stream type.\n// Server and client run sequentially within the NXP event loop goroutine.\nfunc testNXP(port int, stype int, label string) bool {\n\tconst msg = \"hello from go_echo\"\n\tconst timeout = 10 * time.Second\n\n\taddr := fmt.Sprintf(\"nxp://127.0.0.1:%d\", port)\n\n\tsrv, err := nxp.ListenNXP(addr, nil)\n\tif err != nil {\n\t\tlog.Printf(\"[%s] ListenNXP: %v\", label, err)\n\t\treturn false\n\t}\n\tdefer srv.Close()\n\n\tserverDone := make(chan string, 1)\n\tgo func() {\n\t\tctx, cancel := context.WithTimeout(context.Background(), timeout)\n\t\tdefer cancel()\n\t\tconn, err := srv.AcceptContext(ctx)\n\t\tif err != nil {\n\t\t\tlog.Printf(\"[%s][srv] Accept: %v\", label, err)\n\t\t\tserverDone <- \"\"\n\t\t\treturn\n\t\t}\n\t\tdefer conn.Close()\n\t\tif err := conn.WaitReady(ctx); err != nil {\n\t\t\tlog.Printf(\"[%s][srv] WaitReady: %v\", label, err)\n\t\t\tserverDone <- \"\"\n\t\t\treturn\n\t\t}\n\t\tstream, err := conn.AcceptStream(ctx)\n\t\tif err != nil {\n\t\t\tlog.Printf(\"[%s][srv] AcceptStream: %v\", label, err)\n\t\t\tserverDone <- \"\"\n\t\t\treturn\n\t\t}\n\t\tdefer stream.Close()\n\t\trecv := readAll(stream, timeout)\n\t\tstream.WriteFin([]byte(recv)) // echo\n\t\tserverDone <- recv\n\t}()\n\n\tctx, cancel := context.WithTimeout(context.Background(), timeout)\n\tdefer cancel()\n\n\tconn, err := nxp.Dial(addr, nil)\n\tif err != nil {\n\t\tlog.Printf(\"[%s][cli] Dial: %v\", label, err)\n\t\treturn false\n\t}\n\tdefer conn.Close()\n\n\tif err := conn.WaitReady(ctx); err != nil {\n\t\tlog.Printf(\"[%s][cli] WaitReady: %v\", label, err)\n\t\treturn false\n\t}\n\n\tstream, err := conn.OpenStream(stype)\n\tif err != nil {\n\t\tlog.Printf(\"[%s][cli] OpenStream: %v\", label, err)\n\t\treturn false\n\t}\n\tdefer stream.Close()\n\n\tstream.Write([]byte(msg))\n\tstream.Shutdown(nxp.ShutdownWrite)\n\n\t// For reliable/file: verify echo\n\tvar echoOK bool\n\tif stype == nxp.StreamReliable || stype == nxp.StreamFile {\n\t\tgot := readAll(stream, timeout)\n\t\techoOK = got == msg\n\t\tif !echoOK {\n\t\t\tlog.Printf(\"[%s][cli] echo mismatch: got %q\", label, got)\n\t\t}\n\t} else {\n\t\techoOK = true // unreliable: don't check echo\n\t}\n\n\t// Wait server\n\tvar serverRecv string\n\tselect {\n\tcase serverRecv = <-serverDone:\n\tcase <-time.After(timeout):\n\t\tlog.Printf(\"[%s] server timeout\", label)\n\t\treturn false\n\t}\n\n\tif serverRecv != msg {\n\t\tlog.Printf(\"[%s][srv] recv mismatch: got %q\", label, serverRecv)\n\t\treturn false\n\t}\n\n\tstats := conn.Statistics()\n\tlog.Printf(\"[%s] OK  sent=%dB pkts=%d rtt=%dµs\", label,\n\t\tstats.BytesSent, stats.PacketsSent, stats.RTTSmoothedUs)\n\n\treturn echoOK\n}\n\n// readAll reads from a stream until EOF or timeout.\nfunc readAll(stream *nxp.NXPStream, timeout time.Duration) string {\n\tbuf := make([]byte, 4096)\n\tn := 0\n\tdeadline := time.Now().Add(timeout)\n\tfor time.Now().Before(deadline) {\n\t\tnr, err := stream.Read(buf[n:])\n\t\tif nr > 0 {\n\t\t\tn += nr\n\t\t}\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tvar nxpErr *nxp.Error\n\t\t\tif errors.As(err, &nxpErr) && nxpErr.Code == nxp.ErrWouldBlock {\n\t\t\t\ttime.Sleep(2 * time.Millisecond)\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tbreak\n\t\t}\n\t}\n\treturn string(buf[:n])\n}"
